  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:web": "BUILD_PATH=build-web react-scripts build",
    "build:electron": "cross-env PUBLIC_URL=./ react-scripts build",
    "electron:build": "npm run build:electron && electron-builder",
    "electron:build:win": "npm run build:electron && electron-builder --win --x64"
  },
  "build": {
    "extends": null,
    "appId": "com.betabase.app",
    "productName": "Betabase",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "public/icon.png",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "menuCategory": false,
      "shortcutName": "Betabase"
    },
    "compression": "maximum",
    "removePackageScripts": false,
    "mac": {
      "icon": "public/icon.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^32.0.2",
    "electron-builder": "^25.0.5",
    "electron-is-dev": "^3.0.1",
    "postcss-cli": "^11.0.0",
    "postcss-prefix-selector": "^1.16.1"
  },
  "keywords": [],
  "license": "ISC",
  "description": "",
  "homepage": "https://betabase.pro",
  "author": {
    "name": "Betabase Team",
    "email": "support@betabase.pro"
  }
}
