# Nginx — allow ticket image/PDF uploads on api.betabase.pro
#
# 413 Content Too Large usually means nginx rejected the body before Node.js saw it.
# Default client_max_body_size is 1m, which blocks most images.
#
# Add inside the server { } block for api.betabase.pro (or in the location / block):

client_max_body_size 55m;

# Optional: increase timeouts for slow uploads
client_body_timeout 120s;
proxy_read_timeout 120s;
proxy_send_timeout 120s;

# Example location block (adjust upstream port):
#
# server {
#   listen 443 ssl;
#   server_name api.betabase.pro;
#
#   client_max_body_size 55m;
#
#   location / {
#     proxy_pass http://127.0.0.1:5000;
#     proxy_http_version 1.1;
#     proxy_set_header Host $host;
#     proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
#   }
# }
#
# After editing:
#   sudo nginx -t
#   sudo systemctl reload nginx
